<Window x:Class="ConnectWiseManager.Views.DebugLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Debug Log" Height="500" Width="800" WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Margin="10">
            <Button Content="Clear" Width="80" Margin="0,0,10,0" Click="ClearButton_Click"/>
            <Button Content="Copy" Width="80" Click="CopyButton_Click"/>
        </StackPanel>
        <TextBox x:Name="LogTextBox" Grid.Row="1" Margin="10" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" FontFamily="Consolas"/>
    </Grid>
</Window>