<Window x:Class="ConnectWiseManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ConnectWise Manager - Agent Management" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Tab Control -->
        <TabControl Grid.Row="1" Margin="10">
            <!-- Agent List Tab -->
            <TabItem Header="Agent Management">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Field Selection -->
                    <GroupBox Header="Field Selection" Grid.Row="0" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <Label Content="Select fields to display:"/>
                            <ComboBox x:Name="FieldsComboBox" 
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Id"
                                      SelectionChanged="FieldsComboBox_SelectionChanged"/>
                            <WrapPanel Margin="0,10,0,0">
                                <Button Content="Load Agents" Click="LoadAgentsButton_Click" Margin="0,0,10,0" Width="100"/>
                                <CheckBox x:Name="MinimalLoadCheckBox" Content="Minimal ASIO load" Margin="0,0,10,0" VerticalAlignment="Center" ToolTip="Load only Agent Id, Company Friendly Name, Site Friendly Name then commit to static records."/>
                                <CheckBox x:Name="ShowAllDevicesCheckBox" Content="Show All (no OS filter)" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <CheckBox x:Name="StaticFirstCheckBox" Content="Static First (CSV before API)" Margin="0,0,10,0" VerticalAlignment="Center" ToolTip="Load from imported CSV static records first; call API only for missing/unmatched."/>
                                <CheckBox x:Name="BackgroundEnrichCheckBox" Content="Background enrich endpoint details" IsChecked="True" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <Button Content="Cancel Enrich" Click="CancelEnrichButton_Click" Width="120"/>
                                <Button Content="Import ScreenConnect CSV/Excel" Click="ImportScreenConnectCsvButton_Click" Margin="10,0,0,0" Width="220"/>
                                <Button Content="Import ASIO CSV/Excel" Click="ImportAgentsByNameCsvButton_Click" Margin="10,0,0,0" Width="200"/>
                                <Button Content="Find Unmatched" Click="FindUnmatchedButton_Click" Margin="10,0,0,0" Width="130"/>
                                <Button Content="Export Unmatched CSV"
                                        Click="ExportUnmatchedButton_Click"
                                        Margin="10,0,0,0"
                                        Width="180"/>
                                <Button Content="Clear Cache" Click="ClearLocalCacheButton_Click" Margin="10,0,0,0" Width="120" ToolTip="Delete local snapshot cache tables (DeviceSnapshots &amp; NetworkAdapters)."/>
                                <CheckBox x:Name="MacOnlyMatchCheckBox" Content="Relaxed MAC-only match" IsChecked="True" Margin="10,0,0,0" VerticalAlignment="Center" ToolTip="When checked, MAC equality alone marks matched."/>
                                <Button Content="Clear Static" Click="ClearStaticRecordsButton_Click" Margin="10,0,0,0" Width="120" ToolTip="Delete all imported static device records (CSV/API minimal)."/>
                                <Button Content="Load Reporting Companies" Click="LoadReportingCompaniesButton_Click" Margin="10,0,0,0" Width="210" ToolTip="Fetch Reporting API companies."/>
                                <Button Content="Load Reporting Sites" Click="LoadReportingSitesButton_Click" Margin="10,0,0,0" Width="170" ToolTip="Fetch site codes from Reporting API."/>
                                <Button Content="Load Reporting Agents" Click="LoadReportingAgentsButton_Click" Margin="10,0,0,0" Width="180" ToolTip="Fetch agent details for all sites via Reporting API and commit."/>
                                <TextBox x:Name="SiteCodeTextBox" Width="180" Margin="10,0,0,0" ToolTip="Enter SiteCode for Reporting API (case-sensitive)."/>
                                <Button Content="Load Reporting Agents (site)" Click="LoadReportingAgentsForSiteButton_Click" Margin="10,0,0,0" Width="210" ToolTip="Fetch agent details for the specified SiteCode via Reporting API and commit."/>
                                <TextBox x:Name="ReportingApiKeyTextBox" Width="240" Margin="10,0,0,0" ToolTip="Enter Reporting API key (stored locally for this user)."/>
                                <Button Content="Save Reporting Key" Click="SaveReportingApiKeyButton_Click" Margin="5,0,0,0" Width="150" ToolTip="Save the Reporting API key to local user settings."/>
                                <Button Content="Import Reporting Excel" Click="ImportReportingExcelButton_Click" Margin="10,0,0,0" Width="180" ToolTip="Import initial computer/company/site data from Excel to avoid API rate limits."/>
                                <Button Content="Refresh from API" Click="RefreshReportingFromApiButton_Click" Margin="10,0,0,0" Width="150" ToolTip="Check API for changes to cached Reporting data."/>
                            </WrapPanel>
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <GroupBox Header="Reporting Companies" Grid.Column="0" Margin="0,0,5,0">
                                    <ListBox x:Name="ReportingCompaniesListBox"
                                             Height="140"
                                             DisplayMemberPath="DisplayLabel"
                                             SelectionChanged="ReportingCompaniesListBox_SelectionChanged"/>
                                </GroupBox>
                                <GroupBox Header="Reporting Sites" Grid.Column="1" Margin="5,0,0,0">
                                    <ListBox x:Name="ReportingSitesListBox"
                                             Height="140"
                                             DisplayMemberPath="DisplayLabel"
                                             SelectionChanged="ReportingSitesListBox_SelectionChanged"/>
                                </GroupBox>
                            </Grid>
                            <DockPanel Margin="0,10,0,0">
                                <ProgressBar x:Name="EnrichProgressBar" Height="12" Minimum="0" Maximum="100" DockPanel.Dock="Left" Width="300"/>
                                <TextBlock x:Name="EnrichStatusTextBlock" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </DockPanel>
                        </StackPanel>
                    </GroupBox>

                    <!-- Agents DataGrid with explicit columns -->
                    <Grid Grid.Row="1">
                        <Grid.Resources>
                            <!-- Styles: Blue for Asio cells; Red for SC cells; Green when matched -->
                            <Style x:Key="AsioCellStyle" TargetType="TextBlock">
                                <Setter Property="Background" Value="#D0E7FF"/>
                                <Setter Property="Padding" Value="2"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ScreenConnectMatched}" Value="True">
                                        <Setter Property="Background" Value="#C8FACC"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                            <Style x:Key="ScCellStyle" TargetType="TextBlock">
                                <Setter Property="Background" Value="#FFD6D6"/>
                                <Setter Property="Padding" Value="2"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ScreenConnectMatched}" Value="True">
                                        <Setter Property="Background" Value="#C8FACC"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                            <Style x:Key="MatchCellStyle" TargetType="CheckBox">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Style.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter Property="Background" Value="#C8FACC"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Resources>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="300"/>
                        </Grid.ColumnDefinitions>
                        <DataGrid x:Name="AgentsDataGrid"
                                  AutoGenerateColumns="False" 
                                  IsReadOnly="True"
                                  SelectionMode="Extended"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  Margin="0,0,0,10">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="100"/>
                                <DataGridTextColumn Header="Server Ver" Binding="{Binding ServerVersion}" Width="90"/>
                                <DataGridTextColumn Header="Company" Binding="{Binding CompanyName}" Width="160" ElementStyle="{StaticResource AsioCellStyle}"/>
                                <DataGridTextColumn Header="Site" Binding="{Binding SiteName}" Width="140" ElementStyle="{StaticResource AsioCellStyle}"/>
                                <DataGridTextColumn Header="Endpoint (Asio)" Binding="{Binding ComputerName}" Width="200" ElementStyle="{StaticResource AsioCellStyle}"/>
                                <DataGridTextColumn Header="Agent ID" Binding="{Binding Id}" Width="240" ElementStyle="{StaticResource AsioCellStyle}"/>
                                <DataGridTextColumn Header="MAC (Asio)" Binding="{Binding MacAddress}" Width="140" ElementStyle="{StaticResource AsioCellStyle}"/>
                                <DataGridTextColumn Header="All MACs (Asio)" Binding="{Binding AllMacsJoined}" Width="220" ElementStyle="{StaticResource AsioCellStyle}"/>
                                <DataGridCheckBoxColumn Header="SC Match" Binding="{Binding ScreenConnectMatched}" Width="90" ElementStyle="{StaticResource MatchCellStyle}"/>
                                <DataGridTextColumn Header="Endpoint (SC)" Binding="{Binding ScreenConnectName}" Width="200" ElementStyle="{StaticResource ScCellStyle}"/>
                                <DataGridTextColumn Header="MAC (SC)" Binding="{Binding ScreenConnectMac}" Width="140" ElementStyle="{StaticResource ScCellStyle}"/>
                                <DataGridTextColumn Header="OS" Binding="{Binding OperatingSystem}" Width="*"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
                                <DataGridTextColumn Header="Last Seen" Binding="{Binding LastSeen}" Width="180"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>

                    <!-- Actions -->
                    <GroupBox Header="Actions" Grid.Row="2" Padding="10">
                        <WrapPanel>
                            <Button Content="Deploy Installer" 
                                    Click="DeployInstallerButton_Click" 
                                    Margin="5"/>
                            <Button Content="Execute Repair Script" 
                                    Click="ExecuteRepairButton_Click" 
                                    Margin="5"/>
                            <Button Content="Create Session" 
                                    Click="CreateSessionButton_Click" 
                                    Margin="5"/>
                            <Button Content="Send Message" 
                                    Click="SendMessageButton_Click" 
                                    Margin="5"/>
                            <Button Content="Run Custom PowerShell" 
                                    Click="RunCustomPowerShellButton_Click" 
                                    Margin="5"/>
                        </WrapPanel>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- Installer Builder Tab -->
            <TabItem Header="Installer Builder">
                <Grid Margin="10">
                    <GroupBox Header="ScreenConnect Agent Installer Builder" Padding="10">
                        <StackPanel>
                            <Label Content="Company:"/>
                            <TextBox x:Name="CompanyTextBox"/>
                            
                            <Label Content="Site:"/>
                            <TextBox x:Name="SiteTextBox"/>
                            
                            <Label Content="Department:"/>
                            <TextBox x:Name="DepartmentTextBox"/>
                            
                            <Label Content="Device Type:"/>
                            <ComboBox x:Name="DeviceTypeComboBox">
                                <ComboBoxItem Content="Workstation" IsSelected="True"/>
                                <ComboBoxItem Content="Server"/>
                                <ComboBoxItem Content="Laptop"/>
                                <ComboBoxItem Content="Mobile"/>
                            </ComboBox>
                            

                            <Label Content="Installer URL:"/>
                            <TextBox x:Name="InstallerUrlTextBox" 
                                     Text="https://yourdomain.screenconnect.com/installer.exe"/>
                            
                            <Button Content="Build Installer Command" 
                                    Click="BuildInstallerButton_Click" 
                                    HorizontalAlignment="Left" 
                                    Margin="0,20,0,10"/>
                            
                            <Label Content="Generated Command:"/>
                            <TextBox x:Name="GeneratedCommandTextBox" 
                                     TextWrapping="Wrap" 
                                     IsReadOnly="True" 
                                     Height="100" 
                                     VerticalScrollBarVisibility="Auto"/>
                        </StackPanel>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- Field Mapping Tab -->
            <TabItem Header="Field Mapping">
                <Grid Margin="10">
                    <GroupBox Header="Custom Field Mapping" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Map ConnectWise Asio custom fields to local fields" 
                                       TextWrapping="Wrap" 
                                       Margin="0,0,0,10"/>
                            
                            <Button Content="Load Custom Fields" 
                                    Click="LoadCustomFieldsButton_Click" 
                                    HorizontalAlignment="Left" 
                                    Margin="0,0,0,10"/>
                            
                            <DataGrid x:Name="FieldMappingDataGrid" 
                                      AutoGenerateColumns="False" 
                                      CanUserAddRows="True" 
                                      Height="400">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Asio Field" Binding="{Binding Name}" Width="*"/>
                                    <DataGridTextColumn Header="Display Name" Binding="{Binding DisplayName}" Width="*"/>
                                    <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="100"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- Logs Tab -->
            <TabItem Header="Script Logs">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="3*"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="2*"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="LogsDataGrid" 
                              Grid.Row="0"
                              AutoGenerateColumns="False" 
                              IsReadOnly="True"
                              Margin="0,0,0,10">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Session ID" Binding="{Binding SessionId}" Width="150"/>
                            <DataGridTextColumn Header="Device" Binding="{Binding DeviceName}" Width="200"/>
                            <DataGridTextColumn Header="Script Type" Binding="{Binding ScriptType}" Width="150"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                            <DataGridTextColumn Header="Start Time" Binding="{Binding StartTime}" Width="150"/>
                            <DataGridTextColumn Header="End Time" Binding="{Binding EndTime}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <GridSplitter Grid.Row="1" Height="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#DDD" ShowsPreview="True"/>

                    <GroupBox Header="Execution Details" Grid.Row="2" Padding="10">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <TextBlock x:Name="LogDetailsTextBlock" 
                                       TextWrapping="Wrap" 
                                       FontFamily="Consolas"/>
                        </ScrollViewer>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- Session Management Tab -->
            <TabItem Header="Session Management">
                <Grid Margin="10">
                    <GroupBox Header="Active Sessions" Padding="10">
                        <StackPanel>
                            <Label Content="Session ID:"/>
                            <TextBox x:Name="SessionIdTextBox"/>
                            
                            <WrapPanel Margin="0,10,0,0">
                                <Button Content="Get Session Details" 
                                        Click="GetSessionDetailsButton_Click" 
                                        Margin="5"/>
                                <Button Content="Add Note" 
                                        Click="AddNoteButton_Click" 
                                        Margin="5"/>
                                <Button Content="Update Properties" 
                                        Click="UpdatePropertiesButton_Click" 
                                        Margin="5"/>
                            </WrapPanel>
                            
                            <Label Content="Session Details:"/>
                            <TextBox x:Name="SessionDetailsTextBox" 
                                     TextWrapping="Wrap" 
                                     IsReadOnly="True" 
                                     Height="400" 
                                     VerticalScrollBarVisibility="Auto"
                                     FontFamily="Consolas"/>
                        </StackPanel>
                    </GroupBox>
                </Grid>
            </TabItem>
        </TabControl>
        
        <!-- Toolbar with Open Debug Log button -->
        <ToolBarTray VerticalAlignment="Top" Margin="10,0,0,0">
            <ToolBar>
                <Button Content="Open Debug Log" Click="OpenDebugLogButton_Click" Margin="10,0,0,0" Width="140" ToolTip="Open the debug logging window."/>
            </ToolBar>
        </ToolBarTray>
    </Grid>
</Window>
