<Window x:Class="MspTools.App.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="520" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}">

    <StackPanel Margin="24">

        <TextBlock Text="Database Settings" FontSize="15" FontWeight="Bold"
                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>

        <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                   TextWrapping="Wrap" Margin="0,0,0,16">
            MSP Tools uses MySQL to store synced devices, companies, and matches locally.
            Enter the connection string for your MySQL server below.
        </TextBlock>

        <TextBlock Text="MySQL Connection String" FontSize="11"
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
        <TextBox x:Name="ConnectionStringBox"
                 Tag="Server=localhost;Port=3306;Database=msptools;Uid=root;Pwd=;"
                 Margin="0,0,0,8"/>

        <TextBlock x:Name="StatusText" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                   Margin="0,0,0,16" TextWrapping="Wrap"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Test Connection" Style="{StaticResource SecondaryButton}"
                    Margin="0,0,8,0" Click="TestConnection_Click"/>
            <Button Content="Cancel" Style="{StaticResource SecondaryButton}"
                    Margin="0,0,8,0" IsCancel="True" Click="Cancel_Click"/>
            <Button Content="Save" Style="{StaticResource PrimaryButton}"
                    IsDefault="True" Click="Save_Click"/>
        </StackPanel>

    </StackPanel>
</Window>
