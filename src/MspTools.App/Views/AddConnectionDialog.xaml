<Window x:Class="MspTools.App.Views.AddConnectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configure Connection"
        Width="480" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}">

    <StackPanel Margin="24">

        <!-- Section header -->
        <TextBlock Text="Connection Details" FontSize="15" FontWeight="Bold"
                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>

        <!-- Connection Name -->
        <TextBlock Text="Connection Name" FontSize="11"
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                 Tag="My ConnectWise Manage" Margin="0,0,0,12"/>

        <!-- Platform -->
        <TextBlock Text="Platform" FontSize="11"
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
        <ComboBox ItemsSource="{Binding ConnectorTypes}"
                  SelectedItem="{Binding ConnectorType}"
                  Margin="0,0,0,12"/>

        <!-- Base URL -->
        <TextBlock Text="Base URL" FontSize="11"
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
        <TextBox Text="{Binding BaseUrl, UpdateSourceTrigger=PropertyChanged}"
                 Tag="https://na.myconnectwise.net/v4_6_release/apis/3.0"
                 Margin="0,0,0,12"/>

        <!-- Auth Type -->
        <TextBlock Text="Authentication Type" FontSize="11"
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
        <ComboBox ItemsSource="{Binding AuthMethodTypes}"
                  SelectedItem="{Binding SelectedAuthType}"
                  Margin="0,0,0,20"/>

        <!-- ── ConnectWise API Key ── -->
        <StackPanel Visibility="{Binding IsConnectWiseApiKeyAuth,
                                Converter={StaticResource BoolToVis}}">
            <TextBlock Text="ConnectWise Credentials" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>

            <TextBlock Text="Company ID" FontSize="11"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
            <TextBox x:Name="CompanyIdBox"
                     Text="{Binding CompanyId, UpdateSourceTrigger=PropertyChanged}"
                     Tag="e.g. mycompany" Margin="0,0,0,12"/>

            <TextBlock Text="Public Key" FontSize="11"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
            <TextBox Text="{Binding PublicKey, UpdateSourceTrigger=PropertyChanged}"
                     Tag="Public key" Margin="0,0,0,12"/>

            <TextBlock Text="Private Key" FontSize="11"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
            <PasswordBox x:Name="PrivateKeyBox" Margin="0,0,0,12"/>

            <TextBlock Text="Client ID" FontSize="11"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
            <TextBox Text="{Binding ClientId, UpdateSourceTrigger=PropertyChanged}"
                     Tag="Client GUID" Margin="0,0,0,20"/>
        </StackPanel>

        <!-- ── Basic Auth (ESET / Control) ── -->
        <StackPanel Visibility="{Binding IsBasicAuth,
                                Converter={StaticResource BoolToVis}}">
            <TextBlock Text="User Authentication" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>

            <TextBlock Text="Username" FontSize="11"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
            <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                     Tag="Username" Margin="0,0,0,12"/>

            <TextBlock Text="Password" FontSize="11"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
            <PasswordBox x:Name="PasswordBox" Margin="0,0,0,20"/>
        </StackPanel>

        <!-- ── Client Credentials (Asio) ── -->
        <StackPanel Visibility="{Binding IsClientCredentialsAuth,
                                Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Client Credentials" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>

            <TextBlock Text="Client ID" FontSize="11"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
            <TextBox Text="{Binding ClientId, UpdateSourceTrigger=PropertyChanged}"
                     Tag="Client ID" Margin="0,0,0,12"/>

            <TextBlock Text="Client Secret" FontSize="11"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
            <PasswordBox x:Name="ClientSecretBox" Margin="0,0,0,12"/>

            <TextBlock Text="Scope (optional)" FontSize="11"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
            <TextBox Text="{Binding Scope, UpdateSourceTrigger=PropertyChanged}"
                     Tag="platform.devices.read platform.companies.read …"
                     Margin="0,0,0,20"/>
        </StackPanel>

        <!-- ── Bearer Token ── -->
        <StackPanel Visibility="{Binding IsBearerTokenAuth,
                                Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Bearer Token" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>

            <TextBlock Text="Token" FontSize="11"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
            <PasswordBox x:Name="BearerTokenBox" Margin="0,0,0,20"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Style="{StaticResource SecondaryButton}"
                    Margin="0,0,8,0" IsCancel="True"
                    Click="Cancel_Click"/>
            <Button Content="Add Connection" Style="{StaticResource PrimaryButton}"
                    IsDefault="True"
                    Click="AddConnection_Click"/>
        </StackPanel>

    </StackPanel>
</Window>
